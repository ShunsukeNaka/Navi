# いずれか1つを設定すればOK

# Google Gemini（無料）: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq（無料・高速）: https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude（有料）: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Ollama はローカル動作なのでキー不要

# YouTube Live チャット読み取り: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
